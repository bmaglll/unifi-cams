# Address the webhook listener binds to (default: 0.0.0.0)
# Set to 127.0.0.1 to only accept local connections (use with a reverse proxy)
# UNIFI_LISTEN_HOST=127.0.0.1

# Port the webhook listener binds to
UNIFI_LISTEN_PORT=9999

# Seconds to wait before sending another notification for the same camera
UNIFI_COOLDOWN=30

# Bearer token used to authenticate incoming webhooks from UniFi Protect
# (must match the token configured in your Protect webhook settings)
UNIFI_TOKEN=your-token-here

# IP address of your UniFi Protect console (Cloud Key, UNVR, UDM, etc.)
UNIFI_HOST=192.168.1.1

# Minutes to snooze a camera when "Snooze" is clicked on a notification (default: 30)
# UNIFI_SNOOZE_MINS=30

# Path to a sound file to play with each notification (optional)
# Defaults to notification_sound.mp3 in the project folder
# Set to empty string to disable sound
# UNIFI_SOUND=/path/to/custom-sound.mp3

# Start PIP streams muted (set to 1, true, or yes to mute; default: unmuted)
# UNIFI_PIP_MUTED=0

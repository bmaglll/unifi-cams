# Port the webhook listener binds to
PROTECT_LISTEN_PORT=9999

# Seconds to wait before sending another notification for the same camera
PROTECT_COOLDOWN=30

# Bearer token used to authenticate incoming webhooks from UniFi Protect
# (must match the token configured in your Protect webhook settings)
PROTECT_TOKEN=your-token-here

# IP address of your UniFi Protect console (Cloud Key, UNVR, UDM, etc.)
PROTECT_HOST=192.168.1.1

# Camera config as JSON — keys are MAC addresses (no colons, uppercase)
# Each camera needs a "name" and an RTSPS "stream" URL
# You can find MAC addresses in the Protect UI under each camera's settings
# Stream URLs are found in Protect → Camera → Settings → Advanced → RTSP
PROTECT_CAMERAS={"AABBCCDDEEFF":{"name":"Front Door","stream":"rtsps://192.168.1.1:7441/your-stream-token?enableSrtp"}}

# Path to a sound file to play with each notification (optional)
# Defaults to notification_sound.mp3 in the project folder
# Set to empty string to disable sound
# PROTECT_SOUND=/path/to/custom-sound.mp3
